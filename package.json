{
  "name": "agritrust-backend",
  "version": "1.0.0",
  "description": "API for AgriTrust Protocol",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node index.js",
    "preflight": "npx ts-node src/cli/preflight_command.ts",
    "test": "npx vitest run",
    "test:contract": "npx ts-node scripts/run-openapi-contract-tests.ts",
    "test:lock": "npx ts-node tests/integration/silo_lock_test.ts",
    "test:unit": "npx ts-node tests/unit/sensors.test.ts",
    "migrate": "node -e \"require('./src/database/migrate')\""
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^15.4.0",
    "@grpc/grpc-js": "^1.14.4",
    "@noble/curves": "^2.2.0",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.55.0",
    "@opentelemetry/resources": "1.29.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-node": "0.55.0",
    "@opentelemetry/sdk-trace-base": "1.29.0",
    "@opentelemetry/sdk-trace-node": "1.29.0",
    "@opentelemetry/semantic-conventions": "1.27.0",
    "@stellar/stellar-sdk": "^16.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "openapi-types": "^12.1.3",
    "pg": "^8.13.0",
    "prom-client": "^15.1.3",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^4.17.27",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "pg-mem": "^3.0.14",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "uuid": "^14.0.1",
    "vitest": "^2.1.9"
  }
}
